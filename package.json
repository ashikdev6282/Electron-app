{
  "name": "electron-react-sample",
  "version": "1.0.0",
  "description": "Medrec-Q Dictate Desktop Application",
  "main": "electron/main.js",
  "author": "",
  "license": "ISC",
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix ui\" \"electron .\"",
    "build:ui": "npm run build --prefix ui",
    "build": "npm run build:ui && electron-builder"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "lucide-react": "^0.575.0",
    "node-fetch": "^2.7.0"
  },
  "build": {
    "appId": "com.medrec.dictate",
    "productName": "Medrec-Q Dictate",
    "forceCodeSigning": false,
    "compression": "maximum",
    "asar": true,
    "files": [
      "electron/**/*",
      "ui/dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "electron/assets/medrec.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
